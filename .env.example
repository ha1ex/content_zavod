# LLM provider — переключается harness'ом
AI_PROVIDER=anthropic    # anthropic | openai

# Routing: gateway (рекомендуется) | direct | auto (default — gateway если key есть)
AI_GATEWAY=auto

# Vercel AI Gateway (один ключ на все провайдеры + единый биллинг)
# Альтернатива: VERCEL_OIDC_TOKEN из `vercel env pull` (без статического ключа)
AI_GATEWAY_API_KEY=

# Direct providers (используются если gateway недоступен)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4.7

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# Repair loop
HARNESS_MAX_REPAIR_ITERATIONS=3

# Visual regression strategy: auto | playwright | storybook | none
VISUAL_REGRESSION=auto
