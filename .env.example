# LLM provider — переключается harness'ом
AI_PROVIDER=anthropic    # anthropic | openai

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5

# Repair loop
HARNESS_MAX_REPAIR_ITERATIONS=3

# Visual regression strategy: auto | playwright | storybook | none
VISUAL_REGRESSION=auto
