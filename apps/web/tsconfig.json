{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./app/*"],
      "@buffalo/harness": ["../../packages/harness/src"],
      "@buffalo/harness/*": ["../../packages/harness/src/*"],
      "@buffalo/ui": ["../../packages/ui/src"],
      "@buffalo/ui/*": ["../../packages/ui/src/*"]
    },
    "allowJs": true,
    "noEmit": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
